# PostgreSQL is the target production database.
# For local development, create a database and update this URL.
DATABASE_URL="postgresql://latinfun:latinfun@localhost:5432/latinfun?schema=public"

# Set a long random string in every environment.
AUTH_SECRET="replace-with-a-long-random-secret"

# Optional: needed to send student registration verification codes by email.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="\"Classic WordLab\" <no-reply@example.com>"
